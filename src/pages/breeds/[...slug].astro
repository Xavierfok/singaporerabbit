---
import { getCollection, type CollectionEntry } from 'astro:content';
import Breed from '~/layouts/Breed.astro';

export async function getStaticPaths() {
  const all = await getCollection('breeds', ({ data }) => !data.draft);
  return all.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

interface Props { entry: CollectionEntry<'breeds'> }
const { entry } = Astro.props;
const { Content } = await entry.render();
---
<Breed data={entry.data} slug={entry.slug}>
  <Content />
</Breed>
