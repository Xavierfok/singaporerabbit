---
import { getCollection } from 'astro:content';
import Hub from '~/layouts/Hub.astro';

const contributors = await getCollection('contributors', ({ data }) => !data.retired);
---
<Hub
  title="community"
  description="named contributor columns and SG owner stories."
  intro="we're not vets. we're editors. our contributors are SG rabbit owners with skin in the game."
>
  <section>
    <h2 class="font-serif text-xl">contributors</h2>
    {contributors.length === 0 ? (
      <p class="mt-3 text-sm text-ink-soft">we're recruiting. <a href="/contact/">apply for a guest column</a>.</p>
    ) : (
      <ul class="mt-3 grid gap-4 sm:grid-cols-2">
        {contributors.map((c) => (
          <li class="rounded border border-ink/10 p-4">
            <p class="font-serif">{c.data.name}</p>
            <p class="mt-1 text-xs text-ink-soft">joined {c.data.joined}</p>
            <p class="mt-2 text-sm">{c.data.bio}</p>
          </li>
        ))}
      </ul>
    )}
  </section>
</Hub>
