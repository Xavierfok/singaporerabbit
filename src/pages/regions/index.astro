---
import Hub from '~/layouts/Hub.astro';
import { SG_REGIONS } from '~/lib/site';
import { getCollection } from 'astro:content';

const all = await getCollection('directory', ({ data }) => !data.draft);
const byRegion = Object.fromEntries(
  SG_REGIONS.map((r) => [r, all.filter((e) => e.data.region === r)]),
);

const regionBlurbs: Record<string, string> = {
  north: 'Yishun, Sembawang, Woodlands, Admiralty, Mandai. fewer exotic vets but growing pet shop coverage near Sembawang and Woodlands.',
  south: 'Bukit Merah, Telok Blangah, Sentosa-adjacent areas. limited rabbit infrastructure outside of central crossover clinics.',
  east: 'Bedok, Tampines, Pasir Ris, Changi, Katong. strong exotic vet cluster around Bedok and Tampines; popular for rabbit boarding too.',
  west: 'Jurong, Clementi, Bukit Batok, Choa Chu Kang, Tuas. mid-range exotic vet coverage; a few specialty pet shops near Clementi.',
  central: 'Orchard, Novena, Toa Payoh, Bishan, Bukit Timah, Marymount. densest concentration of exotic vets in SG, premium pet shops, most rabbit-savvy groomers.',
};
---
<Hub
  title="rabbit care in Singapore, by region"
  description="find SG rabbit vets, boarding, groomers, shops, and rescues organised by region. north, south, east, west, central."
  intro="rabbit infrastructure is not evenly distributed across Singapore. central has the most exotic vets, east is the strongest for boarding, north and west are growing. pick your region to see everything we have verified in your area."
>
  <section class="grid gap-6 sm:grid-cols-2">
    {SG_REGIONS.map((r) => {
      const entries = byRegion[r] ?? [];
      const counts = {
        vets: entries.filter((e) => e.data.type === 'vets').length,
        groomers: entries.filter((e) => e.data.type === 'groomers').length,
        boarding: entries.filter((e) => e.data.type === 'boarding').length,
        shops: entries.filter((e) => e.data.type === 'shops').length,
        rescues: entries.filter((e) => e.data.type === 'rescues').length,
      };
      const total = entries.length;
      return (
        <a
          href={`/regions/${r}/`}
          class="block rounded border border-ink/10 bg-white p-4 no-underline transition hover:border-accent"
        >
          <h2 class="font-serif text-xl capitalize">{r} Singapore</h2>
          <p class="mt-2 text-sm text-ink-soft">{regionBlurbs[r]}</p>
          <p class="mt-3 text-xs text-ink-soft">
            {total} verified entr{total === 1 ? 'y' : 'ies'}
            {total > 0 && ` · ${counts.vets} vet${counts.vets === 1 ? '' : 's'}, ${counts.shops} shop${counts.shops === 1 ? '' : 's'}, ${counts.boarding} boarding, ${counts.groomers} groomer${counts.groomers === 1 ? '' : 's'}, ${counts.rescues} rescue${counts.rescues === 1 ? '' : 's'}`}
          </p>
        </a>
      );
    })}
  </section>
</Hub>
