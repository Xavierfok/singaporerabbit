---
import { getCollection } from 'astro:content';
import Hub from '~/layouts/Hub.astro';

const contributors = (await getCollection('contributors', ({ data }) => !data.retired))
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---
<Hub
  title="contributors"
  description="the SG rabbit owners who contribute quotes, photos, and columns to singapore rabbits."
  intro="we're editors, not vets. these are the SG owners who lend us their expertise, photos, and time."
>
  {contributors.length === 0 ? (
    <section class="rounded border border-ink/10 bg-white p-5">
      <p class="text-base">we're recruiting our first 5 contributors.</p>
      <p class="mt-3 text-sm text-ink-soft">
        the deal: a quote, a photo, or a guest column per piece. you get a byline, a photo credit,
        and a link back to whatever you'd like (social, shop, blog). we get to write SG-specific
        content with real owner authority.
      </p>
      <p class="mt-3"><a href="/contact/">apply</a></p>
    </section>
  ) : (
    <ul class="grid gap-4 sm:grid-cols-2">
      {contributors.map((c) => (
        <li class="rounded border border-ink/10 p-4">
          <p class="font-serif text-lg">{c.data.name}</p>
          <p class="mt-1 text-xs text-ink-soft">contributing since {c.data.joined}</p>
          <p class="mt-2 text-sm">{c.data.bio}</p>
          {c.data.social && (
            <ul class="mt-2 flex gap-3 text-xs">
              {c.data.social.instagram && <li>instagram: {c.data.social.instagram}</li>}
              {c.data.social.twitter && <li>x: {c.data.social.twitter}</li>}
              {c.data.social.website && <li><a href={c.data.social.website}>website</a></li>}
            </ul>
          )}
        </li>
      ))}
    </ul>
  )}
</Hub>
