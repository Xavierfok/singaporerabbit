---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import SummaryBlock from '~/components/SummaryBlock.astro';
import RelatedPosts from '~/components/RelatedPosts.astro';
import AffiliateDisclosure from '~/components/AffiliateDisclosure.astro';
import Schema from '~/components/Schema.astro';

interface Props {
  data: {
    title: string;
    description: string;
    summary: string;
    last_updated: string;
    published: string;
    contributor?: { id: string };
    tags: string[];
    affiliate_disclosure: boolean;
  };
  slug: string;
}

const { data, slug } = Astro.props;
const crumbs = [
  { name: 'home', href: '/' },
  { name: 'care guides', href: '/care/' },
  { name: data.title.toLowerCase(), href: `/care/${slug}/` },
];

const authorLabel = data.contributor?.id ? data.contributor.id.replace(/-/g, ' ') : 'singapore rabbits team';
const authorHref = data.contributor?.id ? `/contributors/${data.contributor.id}/` : '/about/';

const updatedDate = new Date(data.last_updated);
const updatedLabel = updatedDate.toLocaleDateString('en-SG', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---
<BaseLayout title={data.title} description={data.description}>
  <Breadcrumb items={crumbs} />
  <article class="prose mt-6 max-w-none" data-pagefind-body itemscope itemtype="https://schema.org/Article">
    <h1 class="font-serif text-3xl" itemprop="headline">{data.title}</h1>
    <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-ink-soft">
      <span class="rounded bg-accent-soft px-2 py-0.5 text-xs font-semibold text-accent">
        updated {updatedLabel}
      </span>
      <span itemprop="author" itemscope itemtype="https://schema.org/Person">
        by <a href={authorHref} itemprop="url"><span itemprop="name">{authorLabel}</span></a>
      </span>
      <meta itemprop="datePublished" content={data.published} />
      <meta itemprop="dateModified" content={data.last_updated} />
    </div>
    <SummaryBlock summary={data.summary} lastUpdated={data.last_updated} />
    {data.affiliate_disclosure && <AffiliateDisclosure compact={true} />}
    <div class="mt-6">
      <slot />
    </div>
    <footer class="mt-10 border-t border-ink/10 pt-4 text-sm text-ink-soft">
      <p>
        community-sourced information, not veterinary advice. for medical issues, see a licensed
        SG exotic vet — start with our <a href="/vets/">vet directory</a>.
      </p>
    </footer>
  </article>
  <RelatedPosts collection="guides" currentSlug={slug} tags={data.tags} />
  <Schema type="Article" data={{ ...data, contributor: data.contributor?.id }} />
</BaseLayout>
