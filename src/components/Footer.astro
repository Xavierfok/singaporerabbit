---
import { NAV_DIRECTORY, SITE } from '~/lib/site';
const year = new Date().getFullYear();
---
<footer class="mt-16 border-t border-ink/10 bg-white">
  <section class="mx-auto max-w-5xl px-6 py-8">
    <div class="rounded border border-ink/10 bg-accent-soft/40 p-5 sm:p-6">
      <h2 class="font-serif text-lg">weekly rabbit digest, by email</h2>
      <p class="mt-1 text-sm text-ink-soft">
        new guides, vet updates, and SG-specific seasonal reminders (haze, monsoon, heat waves). one short email a week. no spam, no affiliate pitches in the email.
      </p>
      <form
        action="https://buttondown.email/api/emails/embed-subscribe/YOUR_BUTTONDOWN_USERNAME"
        method="post"
        target="popupwindow"
        onsubmit="window.open('https://buttondown.email/YOUR_BUTTONDOWN_USERNAME', 'popupwindow')"
        class="mt-3 flex flex-col gap-2 sm:flex-row"
      >
        <label for="bd-email" class="sr-only">email address</label>
        <input
          id="bd-email"
          type="email"
          name="email"
          required
          placeholder="your@email.com"
          class="flex-1 rounded border border-ink/10 bg-white px-3 py-2 text-sm outline-none focus:border-accent"
        />
        <input type="hidden" value="1" name="embed" />
        <button
          type="submit"
          class="rounded bg-accent px-4 py-2 text-sm font-semibold text-white transition hover:opacity-90"
        >
          subscribe
        </button>
      </form>
      <p class="mt-2 text-xs text-ink-soft">
        we use <a href="https://buttondown.email/" rel="noopener" class="underline">Buttondown</a>. unsubscribe with one click any time.
      </p>
    </div>
  </section>
  <div class="mx-auto grid max-w-5xl gap-8 px-6 py-10 sm:grid-cols-3">
    <div>
      <p class="font-serif text-lg">{SITE.name}</p>
      <p class="mt-2 text-sm text-ink-soft">{SITE.tagline}</p>
    </div>
    <nav aria-label="directory">
      <p class="text-sm font-semibold uppercase tracking-wide text-ink-soft">directory</p>
      <ul class="mt-2 space-y-1 text-sm">
        {NAV_DIRECTORY.map((n) => (
          <li><a href={n.href} class="no-underline hover:underline">{n.label}</a></li>
        ))}
      </ul>
    </nav>
    <nav aria-label="policies">
      <p class="text-sm font-semibold uppercase tracking-wide text-ink-soft">about</p>
      <ul class="mt-2 space-y-1 text-sm">
        <li><a href="/about/" class="no-underline hover:underline">about</a></li>
        <li><a href="/contributors/" class="no-underline hover:underline">contributors</a></li>
        <li><a href="/contact/" class="no-underline hover:underline">contact</a></li>
        <li><a href="/editorial-policy/" class="no-underline hover:underline">editorial policy</a></li>
        <li><a href="/disclaimer/" class="no-underline hover:underline">disclaimer</a></li>
        <li><a href="/llms.txt" class="no-underline hover:underline">llms.txt</a></li>
      </ul>
    </nav>
  </div>
  <div class="border-t border-ink/10 px-6 py-4 text-center text-xs text-ink-soft">
    © {year} {SITE.name}. community-sourced information, not veterinary advice.
  </div>
</footer>
