---
interface Fact { label: string; value: string }
interface Props { title?: string; facts: Fact[] }
const { title = 'key facts', facts } = Astro.props;
---
<section class="my-6 rounded border border-ink/10 bg-white px-5 py-4" data-keyfacts>
  <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-ink-soft">{title}</h2>
  <dl class="grid gap-2 sm:grid-cols-2">
    {facts.map((f) => (
      <div class="flex flex-col">
        <dt class="text-xs uppercase tracking-wide text-ink-soft">{f.label}</dt>
        <dd class="text-base">{f.value}</dd>
      </div>
    ))}
  </dl>
</section>
