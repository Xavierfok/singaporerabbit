---
import type { CollectionEntry } from 'astro:content';
import Schema from '~/components/Schema.astro';

interface Props { entry: CollectionEntry<'directory'> }
const { entry } = Astro.props;
const d = entry.data;
const href = `/${d.type}/${entry.slug.split('/').pop()}/`;
---
<article
  class="rounded border border-ink/10 bg-white p-4 transition hover:border-accent"
  itemscope
  itemtype="https://schema.org/LocalBusiness"
  data-pagefind-filter={`type:${d.type},region:${d.region},featured:${d.featured ? 'yes' : 'no'}`}
>
  <header class="mb-2 flex items-center justify-between">
    <h3 class="font-serif text-lg" itemprop="name">
      <a href={href} itemprop="url">{d.name}</a>
    </h3>
    {d.featured && (
      <span class="rounded bg-accent-soft px-2 py-0.5 text-xs font-semibold text-accent">featured</span>
    )}
  </header>
  <p class="text-sm text-ink-soft" itemprop="address">{d.address}</p>
  {d.phone && <p class="text-sm" itemprop="telephone">{d.phone}</p>}
  <p class="mt-2 text-sm">{d.summary}</p>
  <p class="mt-2 text-xs text-ink-soft">verified {d.last_verified} · {d.region}</p>
  <Schema type="LocalBusiness" data={d} />
</article>
