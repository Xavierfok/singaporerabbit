---
import { NAV_PRIMARY, SITE } from '~/lib/site';
---
<header class="border-b border-ink/10 bg-white">
  <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-6 py-4">
    <a href="/" class="font-serif text-xl no-underline">{SITE.name}</a>
    <nav aria-label="primary">
      <ul class="flex flex-wrap gap-4 text-sm">
        {NAV_PRIMARY.map((n) => (
          <li>
            <a href={n.href} class="no-underline hover:underline">{n.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
