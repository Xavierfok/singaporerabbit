---
import Schema from '~/components/Schema.astro';

interface Crumb { name: string; href: string }
interface Props { items: Crumb[] }

const { items } = Astro.props;
---
<nav aria-label="breadcrumb" class="text-sm text-ink-soft">
  <ol class="flex flex-wrap gap-1">
    {items.map((it, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <span aria-hidden="true">/</span>}
        {i < items.length - 1 ? (
          <a href={it.href}>{it.name}</a>
        ) : (
          <span class="text-ink">{it.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
<Schema type="BreadcrumbList" data={{ items }} />
