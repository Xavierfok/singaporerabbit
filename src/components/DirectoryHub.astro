---
import { getCollection } from 'astro:content';
import Hub from '~/layouts/Hub.astro';
import DirectoryCard from '~/components/DirectoryCard.astro';
import { SG_REGIONS } from '~/lib/site';

interface Props {
  type: 'vets' | 'groomers' | 'boarding' | 'shops' | 'rescues' | 'breeders';
  title: string;
  description: string;
  intro: string;
  showRegionFilter?: boolean;
}

const { type, title, description, intro, showRegionFilter = true } = Astro.props;
const all = await getCollection('directory', ({ data }) => data.type === type && !data.draft);
const featured = all.filter((e) => e.data.featured);
const others = all.filter((e) => !e.data.featured);
---
<Hub title={title} description={description} intro={intro}>
  {showRegionFilter && (
    <section class="mb-8">
      <h2 class="font-serif text-xl">browse by region</h2>
      <ul class="mt-3 flex flex-wrap gap-2 text-sm">
        {SG_REGIONS.map((r) => (
          <li>
            <a href={`/${type}/by-region/${r}/`} class="rounded border border-ink/10 px-3 py-1 no-underline hover:border-accent">{r}</a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {featured.length > 0 && (
    <section class="mb-8">
      <h2 class="font-serif text-xl">featured</h2>
      <div class="mt-3 grid gap-4 sm:grid-cols-2">
        {featured.map((e) => <DirectoryCard entry={e} />)}
      </div>
    </section>
  )}

  <section>
    <h2 class="font-serif text-xl">all listings</h2>
    {others.length === 0 ? (
      <p class="mt-3 text-sm text-ink-soft">first listings going live in cornerstone burst (month 1). want yours added? <a href="/contact/">tell us</a>.</p>
    ) : (
      <div class="mt-3 grid gap-4 sm:grid-cols-2">
        {others.map((e) => <DirectoryCard entry={e} />)}
      </div>
    )}
  </section>
</Hub>
